# Copy to `.dev.vars` for local `wrangler dev` runs. `.dev.vars` is gitignored.
# In production, set the key as a real secret instead:
#   npx wrangler secret put OPENAI_API_KEY
OPENAI_API_KEY=sk-your-openai-key-for-local-dev-only

# Optional: skip Firebase auth locally so the app's demo mode (no real login)
# can reach the tutor. NEVER enable this in production.
# ALLOW_UNAUTHENTICATED=true
