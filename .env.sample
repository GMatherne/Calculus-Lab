# Firebase — replace with your project values
VITE_FIREBASE_API_KEY=demo
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase App Check (reCAPTCHA Enterprise) site key — OPTIONAL. Attests app
# integrity to Firebase backend services (e.g. Firestore) when you enforce App
# Check in the console. The AI tutor no longer depends on it (the Cloudflare
# proxy verifies the Firebase ID token itself). Leave blank to skip it.
VITE_FIREBASE_APPCHECK_SITE_KEY=

# AI concept tutor — URL of the deployed Cloudflare Worker proxy (see
# tutor-proxy/README.md). When set, the tutor button appears and the browser
# calls this proxy, which holds the OpenAI key server-side and verifies the
# signed-in user. Leave blank to run without the tutor (the app is unchanged).
VITE_TUTOR_PROXY_URL=

# NOTE: the OpenAI API key is NEVER set here. It lives only as a secret on the
# Cloudflare Worker (`wrangler secret put OPENAI_API_KEY`), so it never reaches
# the browser bundle, where it would be extractable and billable by anyone.
# There is intentionally no VITE_OPENAI_* variable.
