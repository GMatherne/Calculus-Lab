        }
      ],
      "interaction": {
        "answer": {
          "type": "drag_drop",
          "prefix": "\\int 3x^2\\,dx =",
          "blanks": [
            {
              "accept": "x^3"
            }
          ],
          "bank": [
            "x^3",
